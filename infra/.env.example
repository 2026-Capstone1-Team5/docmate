POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=document_agent_api
POSTGRES_PORT=5432

REDIS_PORT=6379

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

API_PORT=8000
WEB_PORT=3001
AUTH_SECRET_KEY=dev-only-change-this-key
AUTH_ACCESS_TOKEN_TTL_SECONDS=1800
CORS_ALLOW_ORIGINS=http://127.0.0.1:3001,http://localhost:3001

DOCKER_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/document_agent_api
DOCKER_REDIS_URL=redis://redis:6379/0

DOCKER_STORAGE_BACKEND=r2
STORAGE_BUCKET=document-agent-api
DOCKER_STORAGE_R2_ENDPOINT=http://minio:9000
DOCKER_STORAGE_R2_ACCESS_KEY_ID=minioadmin
DOCKER_STORAGE_R2_SECRET_ACCESS_KEY=minioadmin
STORAGE_R2_REGION=auto

DOCUMENT_AGENT_API_BASE_URL=http://api:8000

QUEUE_BACKEND=redis
PARSE_JOB_QUEUE_NAME=document-agent-api:parse-jobs
WORKER_POLL_TIMEOUT_SECONDS=5
PARSER_TIMEOUT_SECONDS=300
WORKER_TEMP_ROOT=/tmp/document-agent-api-worker
PDFTOTEXT_COMMAND=pdftotext
STORAGE_LOCAL_ROOT=data/storage
