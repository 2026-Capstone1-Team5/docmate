FROM node:22-alpine

ARG NEXT_PUBLIC_DOCUMENT_AI_PARSER_ENABLED
ENV NEXT_PUBLIC_DOCUMENT_AI_PARSER_ENABLED=${NEXT_PUBLIC_DOCUMENT_AI_PARSER_ENABLED:-false}

WORKDIR /workspace/apps/web

RUN corepack enable

COPY apps/web/package.json ./
COPY apps/web/pnpm-lock.yaml ./
COPY apps/web/pnpm-workspace.yaml ./

RUN pnpm install --frozen-lockfile

COPY apps/web ./

RUN pnpm build

EXPOSE 3000

CMD ["pnpm", "start", "--hostname", "0.0.0.0", "--port", "3000"]
